# StudentMap Environment Configuration
# Copy this file to .env and fill in your details to connect to a live Supabase database.
# If these variables are not set, the server will automatically fall back to the local mock database.

PORT=3000

# Supabase Credentials (found under project settings -> API)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-supabase-anon-key
